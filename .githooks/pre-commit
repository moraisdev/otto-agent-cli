#!/usr/bin/env bash
# Pre-commit hook: run Biome lint on staged files
# Blocks commit if there are lint errors

set -euo pipefail

# Guard: never commit the auto-injected <claude-mem-context> memory block.
# It carries session/production context that must not land in git (esp. a public
# repo). If AGENTS.md/CLAUDE.md is staged with the block, strip it and re-stage.
for f in AGENTS.md CLAUDE.md; do
  if git diff --cached --name-only --diff-filter=ACMR | grep -qx "$f" 2>/dev/null \
    && grep -q "<claude-mem-context>" "$f" 2>/dev/null; then
    perl -0pi -e 's/\n*<claude-mem-context>.*?<\/claude-mem-context>\n*/\n/gs' "$f"
    git add "$f"
    echo "Stripped <claude-mem-context> block from $f before commit."
  fi
done

# Get staged .ts/.tsx/.js/.jsx files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "Running biome check on staged files..."

# Run biome check only on staged files
# shellcheck disable=SC2086
if ! bunx biome check --no-errors-on-unmatched $STAGED_FILES; then
  echo ""
  echo "Lint errors found. Fix them before committing."
  echo "Run 'bun run lint:fix' to auto-fix."
  exit 1
fi
