# Copie para omni/.env e ajuste. PGSERVE_DATA DEVE ser caminho absoluto.
DATABASE_URL=postgresql://postgres:postgres@localhost:8532/omni
PGSERVE_EMBEDDED=true
PGSERVE_PORT=8532
PGSERVE_DATA=/ABSOLUTE/PATH/TO/agent-otto/omni/.pgserve-data
NATS_URL=nats://localhost:4222
NATS_MANAGED=false
NATS_PORT=4222
NODE_ENV=development
LOG_LEVEL=info
API_PORT=8882
API_HOST=0.0.0.0
API_MANAGED=false
OMNI_API_KEY=omni_sk_TROQUE_POR_UMA_KEY_FIXA_SUA
